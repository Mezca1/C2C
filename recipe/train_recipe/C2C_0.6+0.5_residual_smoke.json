{
    "model": {
        "base_model": "Qwen/Qwen3-0.6B",
        "teacher_model": "Qwen/Qwen2.5-0.5B-Instruct",
        "is_do_alignment": false,
        "alignment_strategy": "first",
        "projector": {
            "type": "ResidualC2CProjector",
            "params": {
                "hidden_dim": 256,
                "intermediate_dim": 256,
                "num_layers": 3,
                "dropout": 0.1,
                "activation": "gelu",
                "use_layer_norm": true,
                "gate_init_value": 0.0,
                "use_gumbel": true,
                "initial_temperature": 1.0,
                "final_temperature": 0.001,
                "anneal_steps": 32,
                "scalar_temperature": 1.0,
                "zero_init_residual": true,
                "identity_init_align": true
            }
        },
        "mapping": "last_aligned"
    },
    "training": {
        "learning_rate": 1e-4,
        "weight_decay": 0.01,
        "num_epochs": 1,
        "max_length": 512,
        "device": "cuda",
        "scheduler_type": "linear",
        "warmup_ratio": 0.1,
        "max_grad_norm": 1.0,
        "gradient_accumulation_steps": 1,
        "per_device_train_batch_size": 1,
        "num_processes": 1,
        "skip_no_grad_loss": true,
        "freeze": ["teacher", "base"],
        "seed": 42
    },
    "output": {
        "output_dir": "local/checkpoints/0.6+0.5B_residual_smoke",
        "save_steps": 10,
        "eval_steps": 5,
        "wandb_config": {
            "project": "Rosetta",
            "mode": "offline",
            "entity": "nics-efc",
            "run_name": "0.6B+0.5B_residual_smoke"
        }
    },
    "data": {
        "type": "OpenHermesChatDataset",
        "kwargs": {
            "split": "train",
            "max_word_count": null,
            "num_samples": 100
        },
        "train_ratio": 0.99
    }
}
