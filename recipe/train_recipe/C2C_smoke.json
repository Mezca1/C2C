{
    "model": {
        "base_model": "Qwen/Qwen3-0.6B",
        "teacher_model": "Qwen/Qwen2.5-0.5B-Instruct",
        "is_do_alignment": false,
        "alignment_strategy": "first",
        "projector": {
            "type": "C2CProjector",
            "params": {
                "hidden_dim": 256,
                "intermediate_dim": 256,
                "num_layers": 3,
                "dropout": 0.1,
                "initial_temperature": 1.0,
                "final_temperature": 0.001,
                "anneal_steps": 32
            }
        },
        "mapping": "last_aligned"
    },
    "training": {
        "learning_rate": 1e-4,
        "weight_decay": 0.01,
        "num_epochs": 1,
        "max_length": 512,
        "device": "cuda",
        "scheduler_type": "linear",
        "warmup_ratio": 0.1,
        "max_grad_norm": 1.0,
        "gradient_accumulation_steps": 2,
        "per_device_train_batch_size": 1,
        "num_processes": 1,
        "freeze": ["teacher", "base"],
        "seed": 42
    },
    "output": {
        "output_dir": "local/checkpoints/C2C_smoke",
        "save_steps": 20,
        "eval_steps": 10,
        "wandb_config": {
            "project": "Rosetta",
            "mode": "offline",
            "entity": "nics-efc",
            "run_name": "C2C_smoke_openhermes_1k"
        }
    },
    "data": {
        "type": "OpenHermesChatDataset",
        "kwargs": {
            "split": "train",
            "max_word_count": null,
            "num_samples": 1000
        },
        "train_ratio": 0.99
    }
}
